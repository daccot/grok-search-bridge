{
  "manifest_version": 3,
  "name": "Grok Search Bridge",
  "version": "0.3.5",
  "description": "Compact tabbed X search query generator with preset overwrite/save-as, import/export, and reused Grok tab injection.",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "Grok Search Bridge",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "tabs",
    "storage",
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://grok.com/*",
    "https://grok.x.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content.js",
        "grok_inject.js"
      ],
      "run_at": "document_idle"
    }
  ]
}